{
  "name": "@kingen/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx src/integration.test-manual.ts && tsx src/integration.hartenjagen.test-manual.ts && tsx src/integration.klaverjassen.test-manual.ts && tsx src/integration.rikken.test-manual.ts && tsx src/integration.localhost.test-manual.ts"
  },
  "dependencies": {
    "@kingen/shared": "*",
    "sirv": "^3.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0"
  }
}
